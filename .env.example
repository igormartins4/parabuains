# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/parabuains

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Fastify API ─────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
# JWT secret for BFF → API service tokens (min 32 chars, change in production)
API_JWT_SECRET=change-me-in-production-minimum-32-chars

# ─── Next.js (BFF) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_SECRET=change-me-in-production-minimum-32-chars
BETTER_AUTH_URL=http://localhost:3000

# ─── OAuth (Phase 2) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email / Resend (Phase 6) ─────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@parabuains.com

# ─── Web Push / VAPID (Phase 6) ───────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@parabuains.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Internal BFF → API (Phase 3+) ───────────────────────────────────────────
INTERNAL_API_URL=http://localhost:3001

# ─── Cloudflare R2 (Phase 3) ─────────────────────────────────────────────────
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=parabuains-avatars
R2_PUBLIC_URL=https://cdn.parabuains.com

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Sentry (Observability) ───────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_SENTRY_DSN=
